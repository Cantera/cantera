CompileFlags:
  # Use compile_commands.json when present (generated by 'scons build' or 'scons compiledb').
  # Files not in the database (such as test sources when only the library was built) fall
  # back to the flags below. These relative paths are resolved from the project root.
  CompilationDatabase: .
  Add:
    - "-std=c++20"
    - "-Iinclude"
    - "-Ibuild/src"
    - "-isystem"
    - "include/cantera/ext"
    - "-Iext/googletest/googletest/include"
