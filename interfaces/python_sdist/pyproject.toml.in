[build-system]
requires = ["scikit-build-core", "cython @cython_version_spec@", "numpy>=2.0"]
build-backend = "scikit_build_core.build"

[project]
name = "cantera"
version = "@cantera_version@"
description = "Cantera is an open-source suite of tools for problems involving chemical kinetics, thermodynamics, and transport processes."
authors = [{name = "Cantera Developers", email = "developers@cantera.org"}]
keywords = ["chemistry physics"]
license = "BSD-3-Clause"
license-files = ["License.txt"]
classifiers = [
    "Development Status :: 5 - Production/Stable",
    "Intended Audience :: Education",
    "Intended Audience :: Science/Research",
    "Operating System :: MacOS :: MacOS X",
    "Operating System :: Microsoft :: Windows",
    "Operating System :: POSIX :: Linux",
    "Programming Language :: C",
    "Programming Language :: C++",
    "Programming Language :: Cython",
    "Programming Language :: Fortran",
    "Programming Language :: Python :: 3 :: Only",
    "Programming Language :: Python :: 3.12",
    "Programming Language :: Python :: 3.13",
    "Programming Language :: Python :: 3.14",
    "Programming Language :: Python :: Implementation :: CPython",
    "Programming Language :: Python :: Free Threading :: 1 - Unstable",
    "Topic :: Scientific/Engineering :: Chemistry",
    "Topic :: Scientific/Engineering :: Physics",
    "Typing :: Typed",
]
requires-python = "@py_requires_ver_str@"
dependencies = [
    "numpy @numpy_version_spec@",
    "ruamel.yaml @ruamel_version_spec@",
    "typing_extensions >= 4.13.0",
]

[project.readme]
file = "README.rst"
content-type = "text/x-rst"

[project.urls]
Homepage = "https://cantera.org"
Documentation = "https://cantera.org/stable/reference"
Funding = "https://numfocus.org/donate-to-cantera"
Source = "https://github.com/Cantera/cantera"
Tracker = "https://github.com/Cantera/cantera/issues"

[project.optional-dependencies]
pandas = ["pandas"]
units = ["pint"]
graphviz = ["graphviz"]

[project.scripts]
ck2yaml = "cantera.ck2yaml:main"
cti2yaml = "cantera.cti2yaml:main"
ctml2yaml = "cantera.ctml2yaml:main"
yaml2ck = "cantera.yaml2ck:main"
lxcat2yaml = "cantera.lxcat2yaml:main"

[tool.scikit-build]
logging.level = "DEBUG"
build.verbose = true

[tool.scikit-build.cmake]
version = ">=3.27,<4"

[tool.scikit-build.ninja]
version = ">=1.13"
make-fallback = false

[tool.scikit-build.cmake.define]
CMAKE_POSITION_INDEPENDENT_CODE = "ON"
CANTERA_PYODIDE = { env = "CANTERA_PYODIDE", default = "OFF" }
Boost_INCLUDE_DIRS = { env = "Boost_INCLUDE_DIRS" }
HDF5_ROOT = { env = "HDF5_ROOT" }

[tool.scikit-build.sdist]
exclude = ["pyproject.toml.in", "cantera/with_units/solution.py.in"]

[tool.scikit-build.wheel]
# jacobians.py and the other pure-Python-syntax modules listed in PURE_CY_MODULES
# (cantera/CMakeLists.txt) are each built as their own standalone extension linked
# against the shared libcantera. The .py source ships alongside the compiled module so
# IDEs, type checkers, and tracebacks can read it; CPython prefers the extension over
# the source on import.
exclude = ["include", "lib", "share", "**.pyx", "cantera/CMakeLists.txt"]

[[tool.scikit-build.overrides]]
# On Pyodide the pure-Python Cython modules are merged into _cantera rather than built as
# standalone extensions, because emscripten can't share C++ RTTI/data symbols across side
# modules (see interfaces/python_sdist/src/CMakeLists.txt). Exclude their raw .py sources
# from the Pyodide wheel so they don't shadow the merged PyInit_<module> on import. This
# list must be kept in sync with PURE_CY_MODULES in cantera/CMakeLists.txt -- a module
# left off this list ships only as inert .py source on Pyodide (no compiled backing,
# merged or standalone), so importing it fails as soon as it hits Cython-only syntax.
if.env.CANTERA_PYODIDE = "ON"
inherit.wheel.exclude = "append"
wheel.exclude = [
    "cantera/_utils.py", "cantera/jacobians.py", "cantera/constants.py",
    "cantera/units.py", "cantera/func1.py", "cantera/reactionpath.py",
    "cantera/yamlwriter.py", "cantera/speciesthermo.py", "cantera/mixture.py",
    "cantera/transport.py", "cantera/solutionbase.py", "cantera/kinetics.py",
    "cantera/reaction.py", "cantera/thermo.py", "cantera/reactor.py",
    "cantera/_onedim.py", "cantera/delegator.py",
]

[tool.cibuildwheel]
build-frontend = { name="build[uv]", args=["-vv"] }
archs = "auto64"
skip = ["*musllinux*", "cp3??t-win*"]
test-extras = ["pandas", "units", "graphviz"]
test-requires = ["pytest"]
manylinux-x86_64-image = "ghcr.io/cantera/cantera-base-manylinux_2_28-x86_64"
manylinux-aarch64-image = "ghcr.io/cantera/cantera-base-manylinux_2_28-aarch64"
test-command = "pytest -vv --durations=100 ${CANTERA_TEST_DIR}/test/python"

[tool.cibuildwheel.windows]
before-build = "pip install delvewheel"
repair-wheel-command = "delvewheel repair --add-path %HDF5_LIB_DIR%;%SUNDIALS_LIB_DIR% -w {dest_dir} {wheel}"
test-command = "pytest -vv --durations=100 %CANTERA_TEST_DIR%\\test\\python"

[tool.cibuildwheel.macos]
# https://cibuildwheel.pypa.io/en/stable/faq/#macos-passing-dyld_library_path-to-delocate
repair-wheel-command = """\
DYLD_FALLBACK_LIBRARY_PATH=${DYLD_FALLBACK_LIBRARY_PATH} \
delocate-wheel --require-archs {delocate_archs} -w {dest_dir} -v {wheel}
"""
